<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>BusinessRulesManagement</PackageId>
    <Title>BusinessRules Management Framework</Title>
    <Description>A code generation-based framework for defining, managing, and enforcing business rules with Source Generators and Roslyn Analyzers</Description>
    <PackageTags>businessrules;validation;sourcegenerator;analyzer;codegen</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="BusinessRules.Wcf" />
    <InternalsVisibleTo Include="BusinessRules.Wcf.UnitTests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BusinessRulesAnalyzer\BusinessRulesAnalyzer.csproj"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\BusinessRulesFixProvider\BusinessRulesFixProvider.csproj"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\BusinessRulesGenerator\BusinessRulesGenerator.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\BusinessRulesAnalyzer\bin\$(Configuration)\netstandard2.0\BusinessRulesAnalyzer.dll"
          Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="..\BusinessRulesFixProvider\bin\$(Configuration)\netstandard2.0\BusinessRulesFixProvider.dll"
          Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="..\BusinessRulesGenerator\bin\$(Configuration)\netstandard2.0\BusinessRulesGenerator.dll"
          Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <None Include="schemas\businessrules-schema.json" Pack="true" PackagePath="schemas\" />
    <None Include="build\BusinessRulesManagement.props" Pack="true" PackagePath="build\" />
  </ItemGroup>

</Project>
